OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-5.4-mini
OPENAI_API_MODE=responses
OPENAI_REASONING_EFFORT=low
OPENAI_TEXT_VERBOSITY=low
PORT=8787

# Optional: use a compatible proxy endpoint.
# OPENAI_BASE_URL=https://api.openai.com
# For OpenAI-compatible gateways that do not support /v1/responses, set:
# OPENAI_API_MODE=chat

# Optional: if Node.js cannot connect to OpenAI directly, route requests through
# your local HTTP proxy. Common ports are 7890, 7897, 10809, or 20171.
# OPENAI_HTTP_PROXY=http://127.0.0.1:7890
